<%- include('partials/head', { bodyClass: 'menu-body' }) %>

<section class="section-header menu-hero">
  <div>
    <p class="eyebrow">Dondurmacı Zeki</p>
    <% if (selectedSlug === 'all') { %>
      <h1>Menüler</h1>
      <p class="subtitle">Önce bir kategori seç, ardından içindeki lezzetleri keşfet.</p>
    <% } else { %>
      <h1><%= sections[0]?.category?.name || 'Menüler' %></h1>
      <p class="subtitle">Seçili kategorideki ürünler.</p>
    <% } %>
  </div>
  <% if (selectedSlug !== 'all') { %>
    <a class="btn ghost menu-back" href="/menus" aria-label="Menülere geri dön">
      <span aria-hidden="true">←</span>
      <span>Geri</span>
    </a>
  <% } %>
</section>

<% if (sections.length === 0) { %>
  <div class="empty-state">
    <p>Şu anda menümüze ürünler eklenmedi düzenleme bakım aşamasındayız. Anlayışınız için teşekkürler.</p>
  </div>
<% } %>

<% if (selectedSlug === 'all') { %>
  <section class="menu-category-grid" aria-label="Menü kategorileri">
    <% sections.forEach(({ category, products }, index) => { %>
      <% const coverImage = products.find((product) => product.image_path)?.image_path; %>
      <a class="menu-category-card" href="/menus?kategori=<%= category.slug %>" style="--item-index: <%= index %>">
        <% if (coverImage) { %>
          <img src="<%= coverImage %>" alt="<%= category.name %>" loading="<%= index < 3 ? 'eager' : 'lazy' %>" decoding="async" />
        <% } %>
        <span class="menu-category-shade"></span>
        <span class="menu-category-content">
          <span class="menu-category-kicker">Menü</span>
          <strong><%= category.name %></strong>
          <span><%= products.length %> ürün</span>
        </span>
      </a>
    <% }) %>
  </section>
<% } else { %>
  <nav class="menu-filters">
    <% categories.forEach((category) => { %>
      <a class="menu-filter <%= selectedSlug === category.slug ? 'active' : '' %>" href="/menus?kategori=<%= category.slug %>"><%= category.name %></a>
    <% }) %>
  </nav>

  <% sections.forEach(({ category, products }) => { %>
    <section class="menu-section">
      <div class="product-list menu-product-list">
        <% products.forEach((product, index) => { %>
          <article class="product-card menu-product-card" style="--item-index: <%= index %>">
            <% if (product.image_path) { %>
              <img class="product-image" src="<%= product.image_path %>" alt="<%= product.name %>" loading="<%= index < 4 ? 'eager' : 'lazy' %>" decoding="async" />
            <% } %>
            <div class="product-info">
              <div class="product-meta">
                <h3><%= product.name %></h3>
                <% if (product.price) { %>
                  <span class="price"><%= formatPrice(product.price) %></span>
                <% } %>
              </div>
              <% if (product.description) { %>
                <p><%= product.description %></p>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% }) %>
<% } %>

<script>
  (function () {
    const prefetched = new Set();
    const prefetch = (link) => {
      if (!link || !link.href || prefetched.has(link.href)) return;
      prefetched.add(link.href);
      fetch(link.href, { credentials: 'same-origin', priority: 'low' }).catch(() => {});
    };
    document.querySelectorAll('.menu-category-card, .menu-filter, .menu-back').forEach((link) => {
      link.addEventListener('pointerenter', () => prefetch(link), { passive: true });
      link.addEventListener('touchstart', () => prefetch(link), { passive: true });
    });
  })();
</script>

<%- include('partials/footer') %>
