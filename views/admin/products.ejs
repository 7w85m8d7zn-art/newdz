<%- include('../partials/head', { bodyClass: 'admin-body' }) %>

<div class="admin-layout">
  <%- include('../partials/admin_nav', { adminActive: 'menu', adminSub: 'products' }) %>
  <div class="admin-content">
    <h1 class="admin-title">Menü Yönetimi</h1>

    <section class="admin-section">
      <form class="form" method="POST" action="/admin/products" enctype="multipart/form-data">
        <label>
          Kategori
          <select name="categoryId" required>
            <option value="">Seçiniz</option>
            <% categories.forEach((category) => { %>
              <option value="<%= category.id %>"><%= category.name %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Ürün Adı
          <input type="text" name="name" placeholder="Örn: Fıstıklı Künefe" required />
        </label>
        <label>
          Açıklama
          <textarea name="description" rows="2" placeholder="Örn: Üzerine kaymak ve fıstık."></textarea>
        </label>
        <label>
          Fiyat (₺)
          <input type="text" name="price" placeholder="Örn: 160" />
        </label>
        <label>
          Görsel
          <input type="file" name="image" accept="image/*" />
        </label>
        <button class="btn" type="submit">Ürün Ekle</button>
      </form>
    </section>

    <section class="admin-section">
      <div class="table products-table" data-offset="<%= (page - 1) * pageSize %>">
        <div class="table-row table-head">
          <div>Ürün</div>
          <div>Kategori</div>
          <div>Fiyat</div>
          <div>İşlem</div>
        </div>
        <% if (products.length === 0) { %>
          <div class="table-row">
            <div>-</div>
            <div>-</div>
            <div>-</div>
            <div>-</div>
          </div>
        <% } %>
        <% products.forEach((product) => { %>
          <div class="table-row product-row" data-product-id="<%= product.id %>">
            <div>
              <div class="product-title">
                <span class="drag-handle" data-drag-handle title="Sürükle">↕</span>
                <strong><%= product.name %></strong>
              </div>
              <% if (product.image_path) { %>
                <div class="thumb-wrap">
                  <img class="thumb" src="<%= product.image_path %>" alt="<%= product.name %>" loading="lazy" decoding="async" />
                </div>
              <% } %>
              <% if (product.description) { %>
                <div class="muted"><%= product.description %></div>
              <% } %>
            </div>
            <div><%= product.category_name %></div>
            <div><%= product.price ? `₺ ${product.price}` : '-' %></div>
            <div class="actions">
              <form method="POST" action="/admin/products/<%= product.id %>/delete" data-confirm="Silmek istiyor musunuz?">
                <button class="btn ghost" type="submit">Sil</button>
              </form>
              <a class="btn ghost" href="/admin/products/<%= product.id %>/edit">Düzenle</a>
            </div>
          </div>
        <% }) %>
      </div>
    </section>

    <% if (totalPages && totalPages > 1) { %>
      <div class="pagination">
        <% const prevPage = Math.max(1, page - 1); %>
        <% const nextPage = Math.min(totalPages, page + 1); %>
        <a class="btn ghost <%= page === 1 ? 'disabled' : '' %>" href="/admin/products?page=<%= prevPage %>">Önceki</a>
        <span class="pagination-info">Sayfa <%= page %> / <%= totalPages %> (Toplam <%= total %>)</span>
        <a class="btn ghost <%= page === totalPages ? 'disabled' : '' %>" href="/admin/products?page=<%= nextPage %>">Sonraki</a>
      </div>
    <% } %>
  </div>
</div>

<script>
  (function () {
    const table = document.querySelector('.products-table');
    if (!table) return;
    const rows = Array.from(table.querySelectorAll('.product-row'));
    if (rows.length < 2) return;

    let draggingRow = null;

    const getDragAfterElement = (container, y) => {
      const elements = [...container.querySelectorAll('.product-row:not(.dragging)')];
      return elements.reduce(
        (closest, child) => {
          const box = child.getBoundingClientRect();
          const offset = y - box.top - box.height / 2;
          if (offset < 0 && offset > closest.offset) {
            return { offset, element: child };
          }
          return closest;
        },
        { offset: Number.NEGATIVE_INFINITY, element: null }
      ).element;
    };

    const saveOrder = async () => {
      const ids = Array.from(table.querySelectorAll('.product-row'))
        .map((row) => Number(row.dataset.productId))
        .filter((id) => Number.isFinite(id));
      if (!ids.length) return;
      try {
        const res = await fetch('/admin/products/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({
            order: ids,
            offset: Number(table.dataset.offset || 0)
          })
        });
        let payload = null;
        try {
          payload = await res.json();
        } catch (err) {
          payload = null;
        }
        if (!res.ok || !payload?.ok) {
          const message = payload?.error || 'Request failed';
          throw new Error(message);
        }
        if (window.appAlert) {
          window.appAlert('Sıralama güncellendi.');
        }
      } catch (err) {
        if (window.appAlert) {
          window.appAlert(`Sıralama kaydedilemedi: ${err.message || 'hata'}`);
        }
      }
    };

    table.addEventListener('dragover', (event) => {
      if (!draggingRow) return;
      event.preventDefault();
      const after = getDragAfterElement(table, event.clientY);
      if (!after) {
        table.appendChild(draggingRow);
      } else {
        table.insertBefore(draggingRow, after);
      }
    });

    rows.forEach((row) => {
      const handle = row.querySelector('[data-drag-handle]');
      if (!handle) return;
      handle.setAttribute('draggable', 'true');
      handle.addEventListener('dragstart', (event) => {
        draggingRow = row;
        row.classList.add('dragging');
        event.dataTransfer.effectAllowed = 'move';
      });
      handle.addEventListener('dragend', () => {
        row.classList.remove('dragging');
        draggingRow = null;
        saveOrder();
      });
    });
  })();
</script>

<%- include('../partials/footer') %>
