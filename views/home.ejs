<%- include('partials/head', { bodyClass: 'home-body' }) %>

<div class="home-shell" style="<%= settings.background_image ? `--home-bg: url('${settings.background_image}')` : '' %>">
  <div class="home-background">
    <div class="home-bg-image"></div>
    <div class="home-bg-overlay"></div>
    <div class="home-bg-vignette"></div>
  </div>

  <section class="home-content">
    <div class="home-wrapper">
      <div class="home-card home-main-card">
        <div class="home-avatar">
          <div class="home-avatar-inner">
            <% if (settings.logo_image) { %>
              <img src="<%= settings.logo_image %>" alt="Logo" />
            <% } %>
          </div>
        </div>
        <h1 class="home-title"><%= settings.hero_title %></h1>
        <p class="home-slogan"><%- (settings.hero_slogan || '').replace(/\n/g, '<br>') %></p>

        <div class="home-pills">
          <% if (settings.hours_text) { %>
            <div class="home-pill">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 7v5l3 2" />
                <circle cx="12" cy="12" r="9" />
              </svg>
              <span><%= settings.hours_text %></span>
            </div>
          <% } %>
          <% if (settings.phone_text) { %>
            <div class="home-pill">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4l4 1 2 4-2 2c1.6 2.7 4.3 4.9 7 6l2-2 4 2 1 4c-1 1-2.4 2-4 2-7.2 0-13-5.8-13-13 0-1.6 1-3 2-4z" />
              </svg>
              <span><%= settings.phone_text %></span>
            </div>
          <% } %>
        </div>

        <div class="home-social">
          <% if (settings.instagram_url) { %>
            <a class="social-btn" href="<%= settings.instagram_url %>" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="6" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17" cy="7" r="1" />
              </svg>
            </a>
          <% } %>
          <% if (settings.tiktok_url) { %>
            <a class="social-btn" href="<%= settings.tiktok_url %>" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14 4c1.2 2 3 3.2 5 3.4v3.1c-1.9-.1-3.6-.7-5-1.8V16a5 5 0 1 1-4-4.9v3.3a2 2 0 1 0 1.5 1.9V4h2.5z" />
              </svg>
            </a>
          <% } %>
        </div>

        <div class="home-powered"><%= settings.powered_by %></div>
      </div>

      <div class="home-branch-grid">
        <article class="home-card home-branch">
          <div class="branch-header">
            <div>
              <h3><%= settings.branch_name %></h3>
              <p><%= settings.branch_address %></p>
            </div>
            <span class="branch-tag">KONUM</span>
          </div>
          <div class="branch-actions">
            <a class="btn ghost" href="<%= settings.location_url %>" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 21s6-5.2 6-10a6 6 0 0 0-12 0c0 4.8 6 10 6 10z" />
                <circle cx="12" cy="11" r="2.5" />
              </svg>
              <span><%= settings.location_button %></span>
            </a>
            <a class="btn primary" href="/menus"><%= settings.menu_button %></a>
          </div>
        </article>
      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
